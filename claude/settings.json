{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Write(~/worktrees/metadata/**)",
      "Edit(~/worktrees/metadata/**)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(type *)",
      "Bash(file *)",
      "Bash(wc *)",
      "Bash(du *)",
      "Bash(df *)",
      "Bash(date *)",
      "Bash(jq *)",
      "Bash(tree *)",
      "Bash(dirname *)",
      "Bash(basename *)",
      "Bash(realpath *)",
      "Bash(npm test*)",
      "Bash(npm run *)",
      "Bash(npm list*)",
      "Bash(npm info*)",
      "Bash(npx vitest*)",
      "Bash(npx jest*)",
      "Bash(npx tsc*)",
      "Bash(npx eslint*)",
      "Bash(npx prettier*)",
      "Bash(yarn test*)",
      "Bash(yarn run *)",
      "Bash(pnpm test*)",
      "Bash(pnpm run *)",
      "Bash(make *)",
      "Bash(cargo test*)",
      "Bash(cargo build*)",
      "Bash(cargo check*)",
      "Bash(cargo clippy*)",
      "Bash(go test*)",
      "Bash(go build*)",
      "Bash(go vet*)",
      "Bash(python -m pytest*)",
      "Bash(pytest*)",
      "Bash(python -c *)",
      "Bash(brew list*)",
      "Bash(brew info*)",
      "Bash(grove *)",
      "Bash(trellis *)",
      "Bash(sap *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      { "hooks": [{ "type": "command", "command": "sap record --event session-start" }] }
    ],
    "SessionEnd": [
      { "hooks": [{ "type": "command", "command": "sap record --event session-end" }] }
    ],
    "PreToolUse": [
      { "hooks": [{ "type": "command", "command": "sap record --event tool-use" }] }
    ],
    "Stop": [
      { "hooks": [{ "type": "command", "command": "sap record --event turn-complete" }] }
    ],
    "PermissionRequest": [
      { "hooks": [{ "type": "command", "command": "sap record --event attention-permission" }] }
    ],
    "UserPromptSubmit": [
      { "hooks": [{ "type": "command", "command": "sap record --event user-prompt" }] }
    ],
    "Notification": [
      { "hooks": [{ "type": "command", "command": "sap record --event attention-idle" }] }
    ]
  },
  "preferences": {
    "preferredNotifChannel": "notifications_disabled"
  }
}
