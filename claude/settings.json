{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Write",
      "Edit",

      "Bash(git *)",
      "Bash(gh *)",

      "Bash(ls*)",
      "Bash(pwd)",
      "Bash(find *)",
      "Bash(tree*)",
      "Bash(stat *)",
      "Bash(file *)",
      "Bash(which *)",
      "Bash(type *)",
      "Bash(realpath *)",
      "Bash(dirname *)",
      "Bash(basename *)",

      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(du *)",
      "Bash(df *)",
      "Bash(diff *)",
      "Bash(date*)",
      "Bash(echo *)",
      "Bash(printf *)",
      "Bash(uname*)",
      "Bash(env)",
      "Bash(env *)",
      "Bash(printenv*)",

      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(cut *)",
      "Bash(tr *)",
      "Bash(awk *)",
      "Bash(sed *)",
      "Bash(jq *)",
      "Bash(column *)",
      "Bash(xargs *)",
      "Bash(tee *)",
      "Bash(grep *)",
      "Bash(rg *)",

      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(touch *)",
      "Bash(chmod *)",
      "Bash(ln *)",

      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(yarn *)",
      "Bash(pnpm *)",
      "Bash(make *)",
      "Bash(cargo *)",
      "Bash(go *)",
      "Bash(python *)",
      "Bash(pytest *)",

      "Bash(brew *)",
      "Bash(grove *)",
      "Bash(trellis *)",
      "Bash(sap *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      { "hooks": [{ "type": "command", "command": "sap record --event session-start" }] }
    ],
    "SessionEnd": [
      { "hooks": [{ "type": "command", "command": "sap record --event session-end" }] }
    ],
    "PreToolUse": [
      { "hooks": [{ "type": "command", "command": "sap record --event tool-use" }] }
    ],
    "Stop": [
      { "hooks": [{ "type": "command", "command": "sap record --event turn-complete" }] }
    ],
    "PermissionRequest": [
      { "hooks": [{ "type": "command", "command": "sap record --event attention-permission" }] }
    ],
    "UserPromptSubmit": [
      { "hooks": [{ "type": "command", "command": "sap record --event user-prompt" }] }
    ],
    "Notification": [
      { "hooks": [{ "type": "command", "command": "sap record --event attention-idle" }] }
    ]
  },
  "preferences": {
    "preferredNotifChannel": "notifications_disabled"
  }
}
